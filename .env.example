# ============================================
# TELEGRAM FORWARDER BOT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============================================
# TELEGRAM API CREDENTIALS (REQUIRED)
# ============================================
# Get these credentials from: https://my.telegram.org/apps
# 1. Login with your phone number
# 2. Create a new application
# 3. Copy the api_id and api_hash

# Your Telegram API ID (numeric value)
API_ID=12345678

# Your Telegram API Hash (long alphanumeric string)
API_HASH=your_api_hash_here_from_telegram

# ============================================
# SESSION CONFIGURATION
# ============================================
# Session filename (without .session extension)
# This file will be created automatically after first login
# DO NOT delete this file after login - it keeps you authenticated

SESSION_NAME=forwarder_session

# ============================================
# SOURCE CHANNELS (REQUIRED)
# ============================================
# Public channel usernames to monitor messages from
# Format: comma-separated usernames WITHOUT @ symbol
# Example: solearlytrending,solhousesignal,cryptoalerts

# NEW FORMAT - Multiple channels (recommended):
SOURCE_CHANNELS=solearlytrending,solhousesignal

# OLD FORMAT - Single channel (for backward compatibility):
# SOURCE_CHANNEL=solearlytrending

# Alternative: Use channel IDs instead of usernames
# (To get ID: Use @getidsbot in the channel)
# Example: SOURCE_CHANNELS=-1001234567890,-1009876543210

# ============================================
# DESTINATION GROUP (REQUIRED)
# ============================================
# Private group/chat ID where messages will be forwarded
# MUST be a negative number (starts with -100)
# To get your group ID:
# 1. Add @getidsbot to your group
# 2. Send /groupid command
# 3. Copy the number (e.g., -1001234567890)

DESTINATION_GROUP=-1001234567890

# ============================================
# WATERMARK CONFIGURATION (OPTIONAL)
# ============================================
# Custom text to append to forwarded TEXT-ONLY messages
# Watermark is NOT added to media messages (photos, videos, documents)
# Set to empty string to disable watermark completely
# Supports emojis and Unicode characters

WATERMARK=📡 via MyChannel

# Examples:
# WATERMARK=📡 forwarded from @MyChannel
# WATERMARK=
# WATERMARK=🔔 Source: @CryptoNews

# ============================================
# LOG LEVEL (OPTIONAL)
# ============================================
# Controls verbosity of logging
# Options: DEBUG, INFO, WARNING, ERROR
# DEBUG - Shows all details including duplicate skips
# INFO  - Shows normal operations (recommended)
# WARNING - Shows only warnings and errors
# ERROR - Shows only errors

LOG_LEVEL=INFO

# ============================================
# CACHE CONFIGURATION (OPTIONAL)
# ============================================
# Maximum number of message IDs to keep in memory
# Old entries are automatically removed when limit is reached
# Default in code: 1000 messages

# MAX_CACHE_SIZE=1000

# ============================================
# PERFORMANCE TUNING (ADVANCED)
# ============================================
# These settings are used for reconnection logic
# Not currently implemented in main.py but reserved for future use

# Reconnect timeout in seconds
RECONNECT_TIMEOUT=10

# Maximum reconnection attempts before giving up
MAX_RECONNECT_ATTEMPTS=5

# ============================================
# MESSAGE FILTERING (OPTIONAL, DISABLED BY DEFAULT)
# ============================================
# Enable or disable message filtering
# Set to 'true' to enable filtering features
ENABLE_FILTERS=false

# Keyword whitelist - only forward messages containing these keywords
# Leave empty to forward all messages (when filters are enabled)
# Comma-separated list, case-insensitive
# Example: FILTER_KEYWORDS=bitcoin,ethereum,solana,pump,dump
FILTER_KEYWORDS=

# Blocklist - skip messages containing these words
# Comma-separated list, case-insensitive
# Example: FILTER_BLOCKLIST=scam,spam,bot,fake
FILTER_BLOCKLIST=

# Detect cryptocurrency addresses in messages
# Supports Solana (base58) and Ethereum/BSC (0x...) addresses
DETECT_CRYPTO_ADDRESSES=false

# Require crypto address to be present in message
# Only forward messages that contain a detected CA address
REQUIRE_CRYPTO_ADDRESS=false

# Skip "Top Early Trending" leaderboard updates
# Set to 'false' to forward all messages including rankings
# When 'true': Skips leaderboard-style messages (🏆 Top Early Trending, 🥇/🥈/🥉 rankings, etc.)
# When 'false': Forwards all messages including leaderboard updates
SKIP_TRENDING_UPDATES=true

# ============================================
# RATE LIMITING (ADVANCED)
# ============================================
# Minimum delay between forwards (seconds)
RATE_LIMIT_MIN_DELAY=0.5

# Maximum delay between forwards (seconds)
RATE_LIMIT_MAX_DELAY=2.0

# Maximum forwards per minute before pausing
RATE_LIMIT_MAX_PER_MINUTE=30

# ============================================
# LOGGING CONFIGURATION
# ============================================
# Log directory (relative to project root)
LOG_DIR=logs

# Maximum log file size before rotation (in MB)
LOG_MAX_FILE_SIZE=10

# Number of backup log files to keep
LOG_BACKUP_COUNT=5

# Enable verbose console output (DEBUG level)
# Set to 'true' for detailed debugging info
LOG_VERBOSE=false

# ============================================
# ENHANCED MESSAGE FORMATTING (OPTIONAL)
# ============================================
# Enable enhanced formatting for crypto trading signals
# Automatically extracts CA, token info, and generates links
ENABLE_ENHANCED_FORMATTING=true

# Channels to apply enhanced formatting to (comma-separated)
# Example: solearlytrending,solhousesignal,cryptoalerts
# Format: usernames WITHOUT @ symbol
ENHANCED_FORMATTING_CHANNELS=solearlytrending,solhousesignal

# Strip original source channel watermarks
# Removes watermarks like "via @channel", "Subscribe", etc.
STRIP_SOURCE_WATERMARKS=true

# Custom watermark for enhanced formatted messages
# This will be appended at the bottom of reformatted messages
CUSTOM_WATERMARK_ENHANCED=📡 via Fire intern

# Example outputs with enhanced formatting:
# - Extracts Solana CA and generates Pump.fun + DexScreener links
# - Formats with structured layout (header, CA, links, warning)
# - Strips original channel branding
# - Adds your custom watermark

# ============================================
# ADDITIONAL NOTES
# ============================================
# 1. After filling this file, run: python login.py
# 2. Enter your phone number with country code (+1...)
# 3. Enter the verification code from Telegram
# 4. Run: python main.py to start forwarding
# 5. Run with --verbose flag for debug output: python main.py --verbose
# 6. Send /status in destination group to see bot statistics
# 7. Press Ctrl+C to stop the bot (graceful shutdown with cache save)

# For help, see: README.md

